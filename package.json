  "license": "MIT",
  "author": "Vinay Chaganti",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/socraticsurge/atlas-pulse.git"
  },
  "bugs": {
    "url": "https://github.com/socraticsurge/atlas-pulse/issues"
  },
  "homepage": "https://github.com/socraticsurge/atlas-pulse#readme",
  "keywords": [
    "rss",
    "rss-reader",
    "feed-reader",
    "ollama",
    "local-ai",
    "local-first",
    "privacy",
    "react",
    "express"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:frontend\" \"npm run dev:server\"",
    "dev:frontend": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "test": "node --test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.1.0",
