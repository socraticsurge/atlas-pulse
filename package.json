    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "dompurify": "^3.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "vite": "^8.0.9"
  }
